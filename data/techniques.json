{
  "meta": {
    "title": "Guqin Finger-Technique (Hand-Gesture) Reference",
    "description": "A categorized reference of guqin (古琴) finger techniques as written in jianzipu (减字谱) reduced-character tablature. Each entry gives the full character (lookup key), pinyin, the reduced form used in tablature, a plain-language instruction, the traditional poetic gesture-image where one exists, and source links.",
    "version": "1.0.0",
    "note": "Instruction text is paraphrased/summarized for reference purposes. Original demonstration videos and images (Pei-You Chang) and gesture-image scans/translations (John Thompson, silkqin.com) must be sourced and cleared separately — see resources.json licensing."
  },
  "categories": [
    {
      "id": "finger-designation",
      "section": "A",
      "title": "Finger & Hand Designations",
      "subtitle": "左手指法 — which finger presses",
      "hand": "left",
      "description": "Abbreviated finger-name components that appear in the upper-left of a jianzipu glyph to tell the left hand which finger presses. Building blocks rather than strokes.",
      "indexSource": "https://peiyouqin.com/notation3.html"
    },
    {
      "id": "right-stroke-basic",
      "section": "B",
      "title": "Right-Hand Basic Strokes",
      "subtitle": "八法 — the eight basic plucks",
      "hand": "right",
      "description": "The core plucking vocabulary. Each of the four fingers and the thumb plucks either inward (toward the player) or outward (away).",
      "indexSource": "https://peiyouqin.com/notation2.html"
    },
    {
      "id": "right-stroke-compound",
      "section": "B",
      "title": "Right-Hand Compound Strokes",
      "subtitle": "Multi-string & rapid figures",
      "hand": "right",
      "description": "Pinches, wheels, locks, sweeps and rolls built from the eight basic strokes across one or more strings.",
      "indexSource": "https://peiyouqin.com/notation2.html"
    },
    {
      "id": "left-basic",
      "section": "C",
      "title": "Left-Hand Six Basics",
      "subtitle": "The fundamentals — in nearly every piece",
      "hand": "left",
      "description": "Pei-You Chang organizes the left hand around six fundamentals: two vibratos and four slides. Highest-priority entries.",
      "indexSource": "https://peiyouqin.com/notation3b.html"
    },
    {
      "id": "vibrato-variation",
      "section": "D",
      "title": "Vibrato Variations",
      "subtitle": "Sub-types of 吟 yín and 猱 náo",
      "hand": "left",
      "description": "Variations of the two basic vibratos: longer, finer, calmer, faster, immediate, or accented.",
      "indexSource": "https://peiyouqin.com/notation3b.html"
    },
    {
      "id": "slide-strike",
      "section": "E",
      "title": "Slides, Strikes & Ornaments",
      "subtitle": "Advanced left-hand motion",
      "hand": "left",
      "description": "Slow slides, springy strikes-against, and back-and-forth ornaments performed by the left hand.",
      "indexSource": "https://peiyouqin.com/notation3c.html"
    },
    {
      "id": "left-pluck",
      "section": "F",
      "title": "Left-Hand Plucking & Percussive",
      "subtitle": "The left hand makes the sound",
      "hand": "left",
      "description": "Pull-offs, hammer-ons, pushes and advance/return slides where the left hand itself produces the note with no right-hand pluck.",
      "indexSource": "https://silkqin.com/02qnpu/05tydq/ty5d.htm"
    },
    {
      "id": "tone-position",
      "section": "G",
      "title": "Tone-Type & Position Designations",
      "subtitle": "Context glyphs",
      "hand": "either",
      "description": "Glyphs that classify the sound (open / harmonic / stopped) or specify the hui position and string number. Included so a jianzipu reader is complete.",
      "indexSource": "https://peiyouqin.com/notation3.html"
    }
  ],
